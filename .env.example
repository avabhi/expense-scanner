# Application Settings
PROJECT_NAME="Expense Scanner"
VERSION="1.0.0"
API_V1_STR="/api/v1"
ENVIRONMENT="development" # development, production, testing

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/expense_scanner"

# Redis
REDIS_URL="redis://localhost:6379/0"

# AWS / Cloud Storage (MinIO used if ENVIRONMENT="development")
AWS_ACCESS_KEY_ID="mock_key"
AWS_SECRET_ACCESS_KEY="mock_secret"
AWS_REGION="us-east-1"
AWS_BUCKET_NAME="expense-scanner-receipts"
AWS_ENDPOINT_URL="http://localhost:9000" # Use http://minio:9000 inside Docker Compose

# OpenAI / AI Agent (Optional if using Ollama)
OPENAI_API_KEY="sk-..."

# Ollama Local LLM
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="qwen2.5-vl:7b"
